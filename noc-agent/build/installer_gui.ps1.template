    $contentPanel.Controls.Add((New-Subtitle "Questa procedura installera' il nuovo agent nativo della piattaforma 86bit NOC sul server.`n`nL'agent monitora la rete locale (ARP, mDNS, SNMP), si auto-mantiene tramite watchdog dedicato e riceve comandi real-time dal NOC Center."))

    $infoBox = New-Object System.Windows.Forms.GroupBox
