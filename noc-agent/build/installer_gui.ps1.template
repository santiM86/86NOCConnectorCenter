function Reset-Content { $contentPanel.Controls.Clear() }

function Update-Sidebar {
    for ($i = 0; $i -lt $script:StepLabels.Count; $i++) {
        if ($i -eq $script:CurrentStep) {
            $script:StepLabels[$i].ForeColor = $ColorWhite
            $script:StepLabels[$i].Font = New-Object System.Drawing.Font("Segoe UI", 10, [System.Drawing.FontStyle]::Bold)
        } elseif ($i -lt $script:CurrentStep) {
            $script:StepLabels[$i].ForeColor = $ColorSuccess
            $script:StepLabels[$i].Font = New-Object System.Drawing.Font("Segoe UI", 10)
        } else {
            $script:StepLabels[$i].ForeColor = [System.Drawing.Color]::FromArgb(120, 120, 140)
            $script:StepLabels[$i].Font = New-Object System.Drawing.Font("Segoe UI", 10)
        }
    }
}

function New-Title($text) {
    $l = New-Object System.Windows.Forms.Label
    $l.Text = $text
    $l.Font = New-Object System.Drawing.Font("Segoe UI", 18, [System.Drawing.FontStyle]::Bold)
    $l.ForeColor = $ColorText
    $l.Location = [System.Drawing.Point]::new(35, 30)
    $l.Size = New-Object System.Drawing.Size(450, 36)
    return $l
}

function New-Subtitle($text) {
    $l = New-Object System.Windows.Forms.Label
    $l.Text = $text
    $l.Font = New-Object System.Drawing.Font("Segoe UI", 9.5)
    $l.ForeColor = [System.Drawing.Color]::FromArgb(80, 80, 96)
    $l.Location = [System.Drawing.Point]::new(35, 70)
    $l.Size = New-Object System.Drawing.Size(450, 90)
