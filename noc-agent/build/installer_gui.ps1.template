# ================================================================
# HELPERS: ICONA TRAY, SCRIPT TRAY, LAUNCHER CONNECTOR
# ================================================================
function Build-ArgusIcon($Path) {
    # Genera un .ico 32x32 con sfondo blu e "86" bianco bold.
    # Niente file esterni: tutto disegnato runtime via System.Drawing.
    $bmp = New-Object System.Drawing.Bitmap 32, 32
    $g = [System.Drawing.Graphics]::FromImage($bmp)
    $g.SmoothingMode = [System.Drawing.Drawing2D.SmoothingMode]::AntiAlias
    $g.TextRenderingHint = [System.Drawing.Text.TextRenderingHint]::AntiAliasGridFit
    $brushBg = New-Object System.Drawing.SolidBrush ([System.Drawing.Color]::FromArgb(0, 122, 204))
    $g.FillEllipse($brushBg, 0, 0, 31, 31)
    $font = New-Object System.Drawing.Font("Segoe UI", 11, [System.Drawing.FontStyle]::Bold)
    $sf = New-Object System.Drawing.StringFormat
    $sf.Alignment = [System.Drawing.StringAlignment]::Center
    $sf.LineAlignment = [System.Drawing.StringAlignment]::Center
    $rect = New-Object System.Drawing.RectangleF(0, 1, 32, 32)
    $g.DrawString("86", $font, [System.Drawing.Brushes]::White, $rect, $sf)
    $g.Dispose()
    $hIcon = $bmp.GetHicon()
    $icon = [System.Drawing.Icon]::FromHandle($hIcon)
    $fs = New-Object System.IO.FileStream($Path, [System.IO.FileMode]::Create)
    try { $icon.Save($fs) } finally { $fs.Close() }
    $bmp.Dispose()
}

function Write-ConnectorLauncher {
    param([string]$Path, [string]$BackendUrl)
    $body = @"
# 86BIT Argus Connector launcher (avviato dallo shortcut Start Menu).
# 1) Se la tray icon non e' attiva la avvia in hidden.
# 2) Apre il NOC Center nel browser di default.
`$ErrorActionPreference = 'SilentlyContinue'
`$installDir = Split-Path -Parent `$MyInvocation.MyCommand.Path
`$trayScript = Join-Path `$installDir 'tray.ps1'
`$trayRunning = Get-Process -Name powershell -ErrorAction SilentlyContinue |
    Where-Object { `$_.MainWindowTitle -eq '' -and (`$_.CommandLine -match 'tray\\.ps1' -or `$false) }
# Process.CommandLine non e' sempre accessibile: usiamo un mutex via file lock.
`$lock = Join-Path `$env:ProgramData '86NocAgent\\tray.lock'
`$startTray = `$true
if (Test-Path `$lock) {
    `$age = (Get-Date) - (Get-Item `$lock).LastWriteTime
    if (`$age.TotalSeconds -lt 60) { `$startTray = `$false }
}
if (`$startTray -and (Test-Path `$trayScript)) {
    Start-Process -FilePath 'powershell.exe' -ArgumentList @(
        '-NoProfile','-WindowStyle','Hidden','-ExecutionPolicy','Bypass','-File',`$trayScript
    ) -WindowStyle Hidden
}
Start-Process '$BackendUrl'
"@
    Set-Content -Path $Path -Value $body -Encoding UTF8
}

function Write-TrayScript {
    param([string]$Path, [string]$BackendUrl)
    # Usiamo here-string single-quoted per non far interpolare $-vars: il
    # solo placeholder e' __BACKEND_URL__ che sostituiamo a posteriori.
    $body = @'
# 86BIT Argus tray icon - residente nella zona di notifica Windows.
# Avviato all'accesso utente da HKLM\...\Run\86BITArgusTray.
# Mostra stato del servizio 86NocAgent e consente apertura NOC,
# avvio/stop servizi e uscita.
$ErrorActionPreference = 'SilentlyContinue'

# Hide console window
try {
    $sig = @"
[DllImport("user32.dll")] public static extern bool ShowWindow(System.IntPtr hWnd, int nCmdShow);
[DllImport("kernel32.dll")] public static extern System.IntPtr GetConsoleWindow();
"@
    $w = Add-Type -MemberDefinition $sig -Name 'TrayHider' -Namespace 'NocAgent' -PassThru
    $h = $w::GetConsoleWindow()
    if ($h -ne [System.IntPtr]::Zero) { [void]$w::ShowWindow($h, 0) }
} catch { }

# Single-instance lock
$lockDir = Join-Path $env:ProgramData '86NocAgent'
if (-not (Test-Path $lockDir)) { New-Item -ItemType Directory -Force -Path $lockDir | Out-Null }
$lockFile = Join-Path $lockDir 'tray.lock'
$mutex = New-Object System.Threading.Mutex($false, 'Global\86BITArgusTray')
if (-not $mutex.WaitOne(0)) { exit 0 }

Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing

$BackendUrl = '__BACKEND_URL__'
$InstallDir = Split-Path -Parent $MyInvocation.MyCommand.Path
$IconPath   = Join-Path $InstallDir 'argus.ico'

$ni = New-Object System.Windows.Forms.NotifyIcon
if (Test-Path $IconPath) {
    $ni.Icon = New-Object System.Drawing.Icon($IconPath)
} else {
    $ni.Icon = [System.Drawing.SystemIcons]::Application
}
$ni.Text = '86BIT Argus Connector'
$ni.Visible = $true

$menu = New-Object System.Windows.Forms.ContextMenuStrip

$openItem = $menu.Items.Add('Apri NOC Center')
$openItem.add_Click({ Start-Process $BackendUrl })

$statusItem = $menu.Items.Add('Stato: ...')
$statusItem.Enabled = $false

[void]$menu.Items.Add('-')

$startSvc = $menu.Items.Add('Avvia servizi')
$startSvc.add_Click({
    Start-Service -Name '86NocAgent' -ErrorAction SilentlyContinue
    Start-Service -Name '86NocWatchdog' -ErrorAction SilentlyContinue
})
$stopSvc = $menu.Items.Add('Ferma servizi')
$stopSvc.add_Click({
    Stop-Service -Name '86NocWatchdog' -Force -ErrorAction SilentlyContinue
    Stop-Service -Name '86NocAgent' -Force -ErrorAction SilentlyContinue
})
$restartSvc = $menu.Items.Add('Riavvia servizi')
$restartSvc.add_Click({
    Stop-Service -Name '86NocWatchdog' -Force -ErrorAction SilentlyContinue
    Stop-Service -Name '86NocAgent' -Force -ErrorAction SilentlyContinue
    Start-Sleep -Seconds 1
    Start-Service -Name '86NocAgent' -ErrorAction SilentlyContinue
    Start-Service -Name '86NocWatchdog' -ErrorAction SilentlyContinue
})

[void]$menu.Items.Add('-')

$openLog = $menu.Items.Add('Apri cartella log')
$openLog.add_Click({
    $logDir = Join-Path $env:ProgramData '86NocAgent\logs'
    if (-not (Test-Path $logDir)) { New-Item -ItemType Directory -Force -Path $logDir | Out-Null }
    Start-Process explorer.exe $logDir
})

[void]$menu.Items.Add('-')

$exitItem = $menu.Items.Add('Esci dalla tray')
$exitItem.add_Click({
    $script:tickTimer.Stop()
    $ni.Visible = $false
    $ni.Dispose()
    [System.Windows.Forms.Application]::Exit()
})

$ni.ContextMenuStrip = $menu
$ni.add_DoubleClick({ Start-Process $BackendUrl })

# Aggiorna stato ogni 10s
$script:tickTimer = New-Object System.Windows.Forms.Timer
$script:tickTimer.Interval = 10000
$script:tickTimer.add_Tick({
    try {
        $svc = Get-Service -Name '86NocAgent' -ErrorAction Stop
        $statusItem.Text = "Stato servizio: $($svc.Status)"
        if ($svc.Status -eq 'Running') {
            $ni.Text = '86BIT Argus Connector - Online'
        } else {
            $ni.Text = "86BIT Argus Connector - $($svc.Status)"
        }
    } catch {
        $statusItem.Text = 'Servizio non installato'
        $ni.Text = '86BIT Argus Connector - non installato'
    }
    # touch lock per il launcher
    try { (Get-Item $lockFile -ErrorAction SilentlyContinue) | Out-Null } catch { }
    [System.IO.File]::WriteAllText($lockFile, [DateTime]::UtcNow.ToString('o'))
})
$script:tickTimer.Start()

# Touch lock subito
[System.IO.File]::WriteAllText($lockFile, [DateTime]::UtcNow.ToString('o'))

[System.Windows.Forms.Application]::Run()
$mutex.ReleaseMutex()
'@
    $body = $body.Replace('__BACKEND_URL__', $BackendUrl)
    Set-Content -Path $Path -Value $body -Encoding UTF8
}

function Write-UninstallScript {
    param([string]$Path)
    # Disinstallazione completa: nessun residuo dopo l'esecuzione.
    # Lanciato da Programmi e funzionalita' o dallo shortcut Start Menu.
    $body = @'
# 86BIT Argus Connector - disinstallazione completa.
# Rimuove servizi, binari, config, autostart, shortcut, registry entry.
$ErrorActionPreference = 'SilentlyContinue'

# Hide console
try {
    $sig = @"
[DllImport("user32.dll")] public static extern bool ShowWindow(System.IntPtr hWnd, int nCmdShow);
[DllImport("kernel32.dll")] public static extern System.IntPtr GetConsoleWindow();
"@
    $w = Add-Type -MemberDefinition $sig -Name 'UninstHider' -Namespace 'NocAgent' -PassThru
    $h = $w::GetConsoleWindow()
    if ($h -ne [System.IntPtr]::Zero) { [void]$w::ShowWindow($h, 0) }
} catch { }

Add-Type -AssemblyName System.Windows.Forms

# Auto-elevation
$identity = [System.Security.Principal.WindowsIdentity]::GetCurrent()
$principal = New-Object System.Security.Principal.WindowsPrincipal($identity)
if (-not $principal.IsInRole([System.Security.Principal.WindowsBuiltInRole]::Administrator)) {
    $psi = New-Object System.Diagnostics.ProcessStartInfo
    $psi.FileName = 'powershell.exe'
    $psi.Arguments = "-NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File `"$($MyInvocation.MyCommand.Path)`""
    $psi.Verb = 'runas'
    $psi.WindowStyle = [System.Diagnostics.ProcessWindowStyle]::Hidden
    $psi.UseShellExecute = $true
    try { [System.Diagnostics.Process]::Start($psi) | Out-Null } catch { }
    exit 0
}

$confirm = [System.Windows.Forms.MessageBox]::Show(
    "Procedere con la disinstallazione completa di 86BIT Argus Connector?`n`nVerranno rimossi servizi, binari, configurazione e log.",
    '86BIT Argus - Disinstallazione',
    [System.Windows.Forms.MessageBoxButtons]::YesNo,
    [System.Windows.Forms.MessageBoxIcon]::Question)
if ($confirm -ne [System.Windows.Forms.DialogResult]::Yes) { exit 0 }

$installDir = 'C:\Program Files\86NocAgent'
$dataDir    = 'C:\ProgramData\86NocAgent'
$startMenu  = Join-Path $env:ProgramData 'Microsoft\Windows\Start Menu\Programs\86BIT Argus Center'
$logFile    = Join-Path $env:TEMP '86NocAgent-uninstall.log'
"$(Get-Date -Format o) - uninstall start" | Out-File -FilePath $logFile -Append

function Step($msg) { "$(Get-Date -Format o) - $msg" | Out-File -FilePath $logFile -Append }

# 1) Stop + delete servizi
Step 'stop services'
foreach ($s in @('86NocWatchdog','86NocAgent')) {
    Stop-Service -Name $s -Force -ErrorAction SilentlyContinue
}
Start-Sleep -Seconds 1
foreach ($s in @('86NocWatchdog','86NocAgent')) {
    & cmd.exe /c "sc.exe delete `"$s`"" | Out-File -FilePath $logFile -Append
}

# 2) Kill processi tray (powershell che esegue tray.ps1)
Step 'kill tray processes'
Get-CimInstance Win32_Process -Filter "Name='powershell.exe'" -ErrorAction SilentlyContinue | ForEach-Object {
    if ($_.CommandLine -and $_.CommandLine -match 'tray\.ps1') {
        Stop-Process -Id $_.ProcessId -Force -ErrorAction SilentlyContinue
    }
}

# 3) Rimuovi autostart HKLM Run
Step 'remove HKLM Run autostart'
Remove-ItemProperty -Path 'HKLM:\Software\Microsoft\Windows\CurrentVersion\Run' -Name '86BITArgusTray' -Force -ErrorAction SilentlyContinue

# 4) Rimuovi shortcut Start Menu
Step 'remove start menu folder'
if (Test-Path $startMenu) {
    Remove-Item -Path $startMenu -Recurse -Force -ErrorAction SilentlyContinue
}

# 5) Rimuovi entry Programmi e funzionalita'
Step 'remove Add/Remove Programs registry'
Remove-Item -Path 'HKLM:\Software\Microsoft\Windows\CurrentVersion\Uninstall\86BITArgusAgent' -Recurse -Force -ErrorAction SilentlyContinue

# 6) Rimuovi cartelle binari e dati
Step 'remove binaries directory'
# Devo fare la rimozione dell'installDir tramite uno script asincrono
# perche' uninstall.ps1 e' DENTRO installDir e non puo' cancellare se stesso.
$cleanupCmd = @"
Start-Sleep -Seconds 2
Remove-Item -Path '$installDir' -Recurse -Force -ErrorAction SilentlyContinue
Remove-Item -Path '$dataDir' -Recurse -Force -ErrorAction SilentlyContinue
"@
$cleanupPath = Join-Path $env:TEMP '86noc-finalcleanup.ps1'
Set-Content -Path $cleanupPath -Value $cleanupCmd -Encoding UTF8
Start-Process -FilePath 'powershell.exe' -ArgumentList @(
    '-NoProfile','-WindowStyle','Hidden','-ExecutionPolicy','Bypass','-File',$cleanupPath
) -WindowStyle Hidden

[System.Windows.Forms.MessageBox]::Show(
    "Disinstallazione completata.`n`nServizi, binari, configurazione, autostart e voci di registro sono stati rimossi.`n`nLog: $logFile",
    '86BIT Argus - Disinstallazione completata',
    [System.Windows.Forms.MessageBoxButtons]::OK,
    [System.Windows.Forms.MessageBoxIcon]::Information) | Out-Null
'@
    Set-Content -Path $Path -Value $body -Encoding UTF8
}

