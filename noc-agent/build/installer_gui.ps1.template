function Run-Install {
    $script:InstallResult = "fail"
    try {
        [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12 -bor [Net.SecurityProtocolType]::Tls13
        $url = $script:BackendUrl.TrimEnd('/')
        $tok = $script:Token

        Append-Log "[1/11] Lettura manifest installazione" $ColorAccent
        $script:progressBar.Value = 10
        $manifest = Invoke-RestMethod -UseBasicParsing -TimeoutSec 30 `
            -Uri "$url/api/agent/install/manifest?platform=$Platform&role=$($script:Role)&token=$tok"
        $script:ClientId = $manifest.client_id
        Append-Log "      cliente: $($manifest.client_id)  ruolo: $($script:Role)" $ColorSuccess

        Append-Log "[2/11] Stop servizi precedenti (se presenti)" $ColorAccent
        foreach ($s in @($WatchdogName, $ServiceName)) {
            $existing = Get-Service -Name $s -ErrorAction SilentlyContinue
            if ($null -ne $existing) {
                try { Stop-Service -Name $s -Force -ErrorAction SilentlyContinue } catch {}
                & cmd.exe /c "sc.exe delete `"$s`"" | Out-Null
                Start-Sleep -Milliseconds 800
                Append-Log "      $s rimosso" $ColorMuted
            }
        }
        $script:progressBar.Value = 20

        Append-Log "[3/11] Creazione directory" $ColorAccent
        New-Item -ItemType Directory -Force -Path $InstallDir | Out-Null
        New-Item -ItemType Directory -Force -Path $DataDir    | Out-Null
        $script:progressBar.Value = 30

        Append-Log "[4/11] Download nocagent.exe" $ColorAccent
        Invoke-WebRequest -UseBasicParsing -TimeoutSec 120 `
            -Uri "$url/api/agent/binary/$Platform/nocagent.exe?token=$tok" `
            -OutFile (Join-Path $InstallDir "nocagent.exe")
        $script:progressBar.Value = 55

        Append-Log "[5/8] Download nocwatchdog.exe" $ColorAccent
        Invoke-WebRequest -UseBasicParsing -TimeoutSec 120 `
            -Uri "$url/api/agent/binary/$Platform/nocwatchdog.exe?token=$tok" `
            -OutFile (Join-Path $InstallDir "nocwatchdog.exe")
        $script:progressBar.Value = 70

        Append-Log "[6/11] Scrittura $ConfigPath" $ColorAccent
        Set-Content -Path $ConfigPath -Value $manifest.config_template -Encoding UTF8
        $script:progressBar.Value = 80

        Append-Log "[7/11] Registrazione servizi Windows" $ColorAccent
        $agentBin    = Join-Path $InstallDir "nocagent.exe"
        $watchdogBin = Join-Path $InstallDir "nocwatchdog.exe"

        # Usa New-Service (cmdlet nativo PowerShell) per evitare i problemi di
        # parsing argomenti che ha sc.exe quando lanciato direttamente da PS.
        try {
            New-Service -Name $ServiceName `
                -BinaryPathName ('"' + $agentBin + '" --config "' + $ConfigPath + '"') `
                -DisplayName "86bit NOC Agent" `
                -Description "Native NOC monitoring agent for the 86bit platform." `
                -StartupType Automatic -ErrorAction Stop | Out-Null
            Append-Log "      $ServiceName creato" $ColorMuted
        } catch {
            fail-service "create" $ServiceName $_
        }

        try {
            New-Service -Name $WatchdogName `
                -BinaryPathName ('"' + $watchdogBin + '" --config "' + $ConfigPath + '"') `
                -DisplayName "86bit NOC Watchdog" `
                -Description "Supervises 86NocAgent and restarts it on hang or crash." `
                -StartupType Automatic `
                -DependsOn $ServiceName -ErrorAction Stop | Out-Null
            Append-Log "      $WatchdogName creato" $ColorMuted
        } catch {
            fail-service "create" $WatchdogName $_
        }

        # Service Recovery via sc.exe (no PowerShell-native equivalent).
        # Uso cmd /c per preservare la sintassi 'reset= 86400'.
        $recCmd1 = "sc.exe failure `"$ServiceName`" reset= 86400 actions= restart/5000/restart/5000/restart/15000"
        $recCmd2 = "sc.exe failure `"$WatchdogName`" reset= 86400 actions= restart/5000/restart/5000/restart/15000"
        & cmd.exe /c $recCmd1 | Out-Null
        & cmd.exe /c $recCmd2 | Out-Null
        $script:progressBar.Value = 90

        Append-Log "[8/11] Avvio servizi" $ColorAccent
        try {
            Start-Service -Name $ServiceName -ErrorAction Stop
        } catch {
            Append-Log "      WARN: avvio $ServiceName fallito: $($_.Exception.Message)" $ColorError
        }
        Start-Sleep -Seconds 2
        try {
            Start-Service -Name $WatchdogName -ErrorAction Stop
        } catch {
            Append-Log "      WARN: avvio $WatchdogName fallito: $($_.Exception.Message)" $ColorError
        }
        Start-Sleep -Seconds 2

        $ag = Get-Service -Name $ServiceName -ErrorAction SilentlyContinue
        $wd = Get-Service -Name $WatchdogName -ErrorAction SilentlyContinue
        $agStatus = if ($ag) { [string]$ag.Status } else { "MANCANTE" }
        $wdStatus = if ($wd) { [string]$wd.Status } else { "MANCANTE" }

        Append-Log "" $ColorText
        $agColor = if ($agStatus -eq "Running") { $ColorSuccess } else { $ColorError }
        $wdColor = if ($wdStatus -eq "Running") { $ColorSuccess } else { $ColorError }
        Append-Log ("      $ServiceName    : $agStatus") $agColor
        Append-Log ("      $WatchdogName : $wdStatus") $wdColor

        # ============================================================
        # [9/10] Icona + Tray + Start Menu shortcut
        # ============================================================
        Append-Log "" $ColorText
        Append-Log "[9/11] Creazione collegamenti e tray icon" $ColorAccent
        try {
            Build-ArgusIcon (Join-Path $InstallDir "argus.ico")
            Append-Log "      argus.ico generato" $ColorMuted
        } catch {
            Append-Log "      WARN: icona non generata: $($_.Exception.Message)" $ColorError
        }
        try {
            $trayPath = Join-Path $InstallDir "tray.ps1"
            Write-TrayScript -Path $trayPath -BackendUrl $script:BackendUrl
            Append-Log "      tray.ps1 scritto" $ColorMuted
        } catch {
            Append-Log "      WARN: tray.ps1 non scritto: $($_.Exception.Message)" $ColorError
        }
        try {
            $startMenu = Join-Path $env:ProgramData "Microsoft\Windows\Start Menu\Programs\86BIT Argus Center"
            New-Item -ItemType Directory -Force -Path $startMenu | Out-Null
            $wsh = New-Object -ComObject WScript.Shell
            $lnk = $wsh.CreateShortcut((Join-Path $startMenu "Connector.lnk"))
            $lnk.TargetPath = "powershell.exe"
            $lnk.Arguments = "-NoProfile -WindowStyle Hidden -ExecutionPolicy Bypass -File `"$InstallDir\connector.ps1`""
            $lnk.WorkingDirectory = $InstallDir
            $lnk.IconLocation = "$InstallDir\argus.ico,0"
            $lnk.Description = "Apri 86BIT Argus NOC Center"
            $lnk.Save()
            # connector.ps1 = launcher: mostra/avvia tray e apre il NOC nel browser
            Write-ConnectorLauncher -Path (Join-Path $InstallDir "connector.ps1") -BackendUrl $script:BackendUrl
            Append-Log "      shortcut '86BIT Argus Center\Connector' creato" $ColorMuted
        } catch {
            Append-Log "      WARN: shortcut non creato: $($_.Exception.Message)" $ColorError
        }
        $script:progressBar.Value = 95

        # ============================================================
        # [10/10] Autostart tray (HKLM Run, all users) + lancio immediato
        # ============================================================
        Append-Log "[10/11] Registrazione autostart tray e avvio" $ColorAccent
        try {
            $runKey = "HKLM:\Software\Microsoft\Windows\CurrentVersion\Run"
            $trayCmd = "powershell.exe -NoProfile -WindowStyle Hidden -ExecutionPolicy Bypass -File `"$InstallDir\tray.ps1`""
            Set-ItemProperty -Path $runKey -Name "86BITArgusTray" -Value $trayCmd -Force
            Append-Log "      autostart HKLM\\...\\Run\\86BITArgusTray registrato" $ColorMuted
        } catch {
            Append-Log "      WARN: autostart non registrato: $($_.Exception.Message)" $ColorError
        }
        try {
            # Avvia subito la tray icon nella sessione utente corrente.
            # Lo script tray.ps1 rileva da solo se c'e' gia' un'altra
            # istanza in esecuzione e in tal caso esce.
            $trayPath = Join-Path $InstallDir "tray.ps1"
            if (Test-Path $trayPath) {
                Start-Process -FilePath "powershell.exe" -ArgumentList @(
                    "-NoProfile", "-WindowStyle", "Hidden",
                    "-ExecutionPolicy", "Bypass",
                    "-File", $trayPath
                ) -WindowStyle Hidden | Out-Null
                Append-Log "      tray icon avviata" $ColorMuted
            }
        } catch {
            Append-Log "      WARN: avvio tray fallito: $($_.Exception.Message)" $ColorError
        }

        # ============================================================
        # [11/11] Registrazione 'Programmi e funzionalita'' + uninstall.ps1
        # ============================================================
        Append-Log "[11/11] Registrazione Programmi e funzionalita'" $ColorAccent
        try {
            $uninstPath = Join-Path $InstallDir "uninstall.ps1"
            Write-UninstallScript -Path $uninstPath
            Append-Log "      uninstall.ps1 scritto" $ColorMuted
        } catch {
            Append-Log "      WARN: uninstall.ps1 non scritto: $($_.Exception.Message)" $ColorError
        }
        try {
            $uninstKey = "HKLM:\Software\Microsoft\Windows\CurrentVersion\Uninstall\86BITArgusAgent"
            if (-not (Test-Path $uninstKey)) {
                New-Item -Path $uninstKey -Force | Out-Null
            }
            $uninstCmd = "powershell.exe -NoProfile -WindowStyle Hidden -ExecutionPolicy Bypass -File `"$InstallDir\uninstall.ps1`""
            $sizeKb = 0
            try {
                $sizeBytes = (Get-ChildItem -Path $InstallDir -Recurse -ErrorAction SilentlyContinue | Measure-Object Length -Sum).Sum
                if ($sizeBytes) { $sizeKb = [int]($sizeBytes / 1024) }
            } catch { }
            Set-ItemProperty -Path $uninstKey -Name 'DisplayName'     -Value '86BIT Argus Connector'
            Set-ItemProperty -Path $uninstKey -Name 'DisplayVersion'  -Value $Version
            Set-ItemProperty -Path $uninstKey -Name 'Publisher'       -Value '86bit S.r.l.'
            Set-ItemProperty -Path $uninstKey -Name 'URLInfoAbout'    -Value 'https://www.86bit.it'
            Set-ItemProperty -Path $uninstKey -Name 'InstallLocation' -Value $InstallDir
            Set-ItemProperty -Path $uninstKey -Name 'UninstallString' -Value $uninstCmd
            Set-ItemProperty -Path $uninstKey -Name 'QuietUninstallString' -Value $uninstCmd
            Set-ItemProperty -Path $uninstKey -Name 'DisplayIcon'     -Value "$InstallDir\argus.ico"
            Set-ItemProperty -Path $uninstKey -Name 'NoModify'        -Value 1 -Type DWord
            Set-ItemProperty -Path $uninstKey -Name 'NoRepair'        -Value 1 -Type DWord
            if ($sizeKb -gt 0) {
                Set-ItemProperty -Path $uninstKey -Name 'EstimatedSize' -Value $sizeKb -Type DWord
            }
            Set-ItemProperty -Path $uninstKey -Name 'InstallDate'     -Value (Get-Date -Format 'yyyyMMdd')
            Append-Log "      voce 'Programmi e funzionalita'' registrata" $ColorMuted
        } catch {
            Append-Log "      WARN: registry Uninstall non scritto: $($_.Exception.Message)" $ColorError
        }
        try {
            # Aggiunge anche shortcut 'Disinstalla' nel menu Start
            $startMenu = Join-Path $env:ProgramData "Microsoft\Windows\Start Menu\Programs\86BIT Argus Center"
            if (-not (Test-Path $startMenu)) {
                New-Item -ItemType Directory -Force -Path $startMenu | Out-Null
            }
            $wsh = New-Object -ComObject WScript.Shell
            $unLnk = $wsh.CreateShortcut((Join-Path $startMenu "Disinstalla.lnk"))
            $unLnk.TargetPath = "powershell.exe"
            $unLnk.Arguments = "-NoProfile -WindowStyle Hidden -ExecutionPolicy Bypass -File `"$InstallDir\uninstall.ps1`""
            $unLnk.WorkingDirectory = $InstallDir
            $unLnk.IconLocation = "$InstallDir\argus.ico,0"
            $unLnk.Description = "Disinstalla 86BIT Argus Connector"
            $unLnk.Save()
            Append-Log "      shortcut 'Disinstalla' creato" $ColorMuted
        } catch {
            Append-Log "      WARN: shortcut Disinstalla non creato: $($_.Exception.Message)" $ColorError
        }

        $script:progressBar.Value = 100
        if ($agStatus -eq 'Running' -and $wdStatus -eq 'Running') {
            $script:InstallResult = "ok"
            Append-Log "" $ColorText
            Append-Log (([char]0x2713) + " Installazione completata con successo.") $ColorSuccess
        } else {
            Append-Log "" $ColorText
            Append-Log (([char]0x26A0) + " Installazione completata ma servizi NON in stato Running.") $ColorError
        }
    } catch {
        Append-Log ""
        Append-Log "ERRORE: $($_.Exception.Message)" $ColorError
        $script:InstallResult = "fail"
    }
    $btnNext.Enabled = $true
    $btnCancel.Enabled = $true
    $btnNext.Text = "Avanti >"
}

# ================================================================
# STEP 4 - FINE
# ================================================================
function Show-Done {
    Reset-Content
    $btnBack.Enabled = $false
    $btnNext.Text = "Chiudi"
    $btnCancel.Enabled = $false

    if ($script:InstallResult -eq "ok") {
        $contentPanel.Controls.Add((New-Title "Installazione completata"))
        $contentPanel.Controls.Add((New-Subtitle "Il connector e' attivo come Windows Service e si connettera' al NOC Center.`n`nIl supervisore (watchdog) lo manterra' in esecuzione anche in caso di crash o blocco di un modulo."))

        $box = New-Object System.Windows.Forms.GroupBox
        $box.Text = "Prossimi passi"
        $box.Location = [System.Drawing.Point]::new(35, 170)
        $box.Size = New-Object System.Drawing.Size(450, 220)
        $box.Font = New-Object System.Drawing.Font("Segoe UI", 9, [System.Drawing.FontStyle]::Bold)
        $contentPanel.Controls.Add($box)

        $items = @(
            "Menu Start -> 86BIT Argus Center -> Connector",
            "Tray icon visibile vicino all'orologio (zona notifica)",
            "Apri il NOC Center -> Agents per verificare 'live: true'",
            "Per disinstallare: Pannello di controllo -> Programmi"
        )
        for ($i = 0; $i -lt $items.Count; $i++) {
            $l = New-Object System.Windows.Forms.Label
            $l.Text = ([char]0x2192) + "  " + $items[$i]
            $l.Font = New-Object System.Drawing.Font("Segoe UI", 9.5)
            $l.ForeColor = $ColorText
            $l.Location = [System.Drawing.Point]::new(20, 30 + ($i * 30))
            $l.Size = New-Object System.Drawing.Size(420, 26)
            $box.Controls.Add($l)
        }
    } else {
        $contentPanel.Controls.Add((New-Title "Installazione fallita"))
        $contentPanel.Controls.Add((New-Subtitle "Si e' verificato un errore durante l'installazione.`n`nControlla il log dello step precedente. Eventuali servizi parzialmente registrati possono essere rimossi manualmente."))

        $box = New-Object System.Windows.Forms.GroupBox
        $box.Text = "Disinstallazione manuale"
        $box.Location = [System.Drawing.Point]::new(35, 170)
        $box.Size = New-Object System.Drawing.Size(450, 200)
        $box.Font = New-Object System.Drawing.Font("Segoe UI", 9, [System.Drawing.FontStyle]::Bold)
        $contentPanel.Controls.Add($box)

        $cmd = New-Object System.Windows.Forms.TextBox
        $cmd.Multiline = $true
        $cmd.ReadOnly = $true
        $cmd.ScrollBars = [System.Windows.Forms.ScrollBars]::Vertical
        $cmd.Font = New-Object System.Drawing.Font("Consolas", 9)
        $cmd.Location = [System.Drawing.Point]::new(15, 25)
        $cmd.Size = New-Object System.Drawing.Size(420, 160)
        $cmd.Text = @"
Stop-Service $ServiceName, $WatchdogName -Force -ErrorAction SilentlyContinue
sc.exe delete $ServiceName
sc.exe delete $WatchdogName
Remove-Item -Recurse -Force "$InstallDir","$DataDir"
"@
        $box.Controls.Add($cmd)
    }
}

# ================================================================
# NAVIGAZIONE
# ================================================================
function Render-Step {
    Update-Sidebar
    switch ($script:CurrentStep) {
        0 { Show-Welcome }
        1 { Show-Mode }
        2 { Show-Configuration }
        3 { Show-Summary }
        4 { Show-Install }
        5 { Show-Done }
    }
}

$btnNext.Add_Click({
    if ($script:CurrentStep -eq 1) {
        # Persiste la scelta del ruolo
        if ($script:rbScanner -ne $null -and $script:rbScanner.Checked) {
            $script:Role = "scanner"
        } else {
            $script:Role = "master"
        }
    }
    if ($script:CurrentStep -eq 2) {
        # Validazione step Configurazione
        $url = $script:txtUrl.Text.TrimEnd('/')
        $tok = $script:txtToken.Text.Trim()
        if (-not $url -or -not $tok) {
            [System.Windows.Forms.MessageBox]::Show("URL e Token sono obbligatori.", "Configurazione incompleta",
                [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Warning) | Out-Null
            return
        }
        $script:BackendUrl = $url
        $script:Token = $tok
        if (-not $script:ClientId) {
            try {
                [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12 -bor [Net.SecurityProtocolType]::Tls13
                $r = Invoke-RestMethod -UseBasicParsing -TimeoutSec 15 `
                    -Uri "$url/api/agent/install/manifest?platform=$Platform&role=$($script:Role)&token=$tok"
                $script:ClientId = $r.client_id
            } catch {
                [System.Windows.Forms.MessageBox]::Show("Verifica fallita:`n$($_.Exception.Message)", "Errore connessione",
                    [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Error) | Out-Null
                return
            }
        }
    }
    if ($script:CurrentStep -eq 5) { $form.Close(); return }
    $script:CurrentStep++
    Render-Step
})

$btnBack.Add_Click({
    if ($script:CurrentStep -gt 0) {
        $script:CurrentStep--
        Render-Step
    }
})

$btnCancel.Add_Click({
    if ([System.Windows.Forms.MessageBox]::Show("Annullare l'installazione?", "$DisplayName",
        [System.Windows.Forms.MessageBoxButtons]::YesNo,
        [System.Windows.Forms.MessageBoxIcon]::Question) -eq [System.Windows.Forms.DialogResult]::Yes) {
        $form.Close()
    }
})

# ================================================================
# AVVIO
# ================================================================
Render-Step
[void]$form.ShowDialog()
