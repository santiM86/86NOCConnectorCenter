$script:lstLog = $null
$script:progressBar = $null

function Append-Log($text, $color) {
    if (-not $color) { $color = $ColorText }
    try {
        $script:lstLog.SelectionColor = $color
    } catch { }
    $script:lstLog.AppendText("$text`r`n")
    $script:lstLog.ScrollToCaret()
    [System.Windows.Forms.Application]::DoEvents()
}

function fail-service($verb, $name, $err) {
    $msg = $err.Exception.Message
    Append-Log "      ERRORE $verb '$name': $msg" $ColorError
    throw "service $verb $name failed: $msg"
}

