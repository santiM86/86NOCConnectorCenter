function Reset-Content { $contentPanel.Controls.Clear() }

function Update-Sidebar {
    for ($i = 0; $i -lt $script:StepLabels.Count; $i++) {
        if ($i -eq $script:CurrentStep) {
            $script:StepLabels[$i].ForeColor = $ColorWhite
            $script:StepLabels[$i].Font = New-Object System.Drawing.Font("Segoe UI", 10, [System.Drawing.FontStyle]::Bold)
        } elseif ($i -lt $script:CurrentStep) {
            $script:StepLabels[$i].ForeColor = $ColorSuccess
            $script:StepLabels[$i].Font = New-Object System.Drawing.Font("Segoe UI", 10)
        } else {
            $script:StepLabels[$i].ForeColor = [System.Drawing.Color]::FromArgb(120, 120, 140)
            $script:StepLabels[$i].Font = New-Object System.Drawing.Font("Segoe UI", 10)
        }
    }
}

