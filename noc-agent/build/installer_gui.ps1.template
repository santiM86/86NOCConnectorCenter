    $script:txtUrl.Size = New-Object System.Drawing.Size(440, 26)
    $script:txtUrl.Text = $script:BackendUrl
    $contentPanel.Controls.Add($script:txtUrl)

    $hintUrl = New-Object System.Windows.Forms.Label
    $hintUrl.Text = "Es: https://argus.86bit.it"
    $hintUrl.Font = New-Object System.Drawing.Font("Segoe UI", 8)
    $hintUrl.ForeColor = $ColorMuted
    $hintUrl.Location = [System.Drawing.Point]::new(35, 202)
    $hintUrl.Size = New-Object System.Drawing.Size(440, 18)
    $contentPanel.Controls.Add($hintUrl)

    # Token
    $lblToken = New-Object System.Windows.Forms.Label
    $lblToken.Text = "Token cliente *"
    $lblToken.Font = New-Object System.Drawing.Font("Segoe UI", 9, [System.Drawing.FontStyle]::Bold)
    $lblToken.Location = [System.Drawing.Point]::new(35, 240)
    $lblToken.Size = New-Object System.Drawing.Size(200, 20)
    $contentPanel.Controls.Add($lblToken)

    $script:txtToken = New-Object System.Windows.Forms.TextBox
    $script:txtToken.Font = New-Object System.Drawing.Font("Consolas", 9)
    $script:txtToken.Location = [System.Drawing.Point]::new(35, 262)
    $script:txtToken.Size = New-Object System.Drawing.Size(440, 26)
    $script:txtToken.Text = $script:Token
    $contentPanel.Controls.Add($script:txtToken)

    $hintTok = New-Object System.Windows.Forms.Label
    $hintTok.Text = "Generato dall'admin con  POST /api/agents/register"
    $hintTok.Font = New-Object System.Drawing.Font("Segoe UI", 8)
    $hintTok.ForeColor = $ColorMuted
    $hintTok.Location = [System.Drawing.Point]::new(35, 292)
    $hintTok.Size = New-Object System.Drawing.Size(440, 18)
    $contentPanel.Controls.Add($hintTok)

    # Bottone test connessione
    $btnTest = New-Object System.Windows.Forms.Button
    $btnTest.Text = "Verifica connessione"
    $btnTest.Size = New-Object System.Drawing.Size(180, 30)
    $btnTest.Location = [System.Drawing.Point]::new(35, 330)
    $btnTest.FlatStyle = [System.Windows.Forms.FlatStyle]::Flat
    $btnTest.BackColor = $ColorWhite
    $btnTest.Font = New-Object System.Drawing.Font("Segoe UI", 9)
    $contentPanel.Controls.Add($btnTest)

    $script:lblValidation = New-Object System.Windows.Forms.Label
    $script:lblValidation.Font = New-Object System.Drawing.Font("Segoe UI", 9)
    $script:lblValidation.Location = [System.Drawing.Point]::new(225, 335)
    $script:lblValidation.Size = New-Object System.Drawing.Size(260, 24)
    $script:lblValidation.Text = ""
    $contentPanel.Controls.Add($script:lblValidation)

    $btnTest.Add_Click({
        $url = $script:txtUrl.Text.TrimEnd('/')
        $tok = $script:txtToken.Text.Trim()
        if (-not $url -or -not $tok) {
            $script:lblValidation.ForeColor = $ColorError
            $script:lblValidation.Text = "URL e Token obbligatori."
            return
        }
        $script:lblValidation.ForeColor = $ColorMuted
        $script:lblValidation.Text = "Verifica in corso..."
        $contentPanel.Refresh()
        try {
            [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12 -bor [Net.SecurityProtocolType]::Tls13
            $resp = Invoke-RestMethod -UseBasicParsing -TimeoutSec 15 `
                -Uri "$url/api/agent/install/manifest?platform=$Platform&role=$($script:Role)&token=$tok"
            $script:ClientId = $resp.client_id
            $script:lblValidation.ForeColor = $ColorSuccess
            $script:lblValidation.Text = ([char]0x2713) + " OK - cliente: $($resp.client_id)"
        } catch {
            $script:lblValidation.ForeColor = $ColorError
            $script:lblValidation.Text = ([char]0x2717) + " " + $_.Exception.Message
        }
    })
}

