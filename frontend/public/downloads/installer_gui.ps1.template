$btnImp = New-Btn 'Importa CSV' 160 545 130 $ColAccent $ColWhite {
    $od = New-Object System.Windows.Forms.OpenFileDialog
    $od.Filter = 'CSV (*.csv)|*.csv'
    if ($od.ShowDialog() -eq 'OK') {
        try {
            $rows = @()
            $delim = ','
            $firstLine = (Get-Content -Path $od.FileName -TotalCount 1)
            if ($firstLine -match ';') { $delim = ';' } elseif ($firstLine -match "`t") { $delim = "`t" }
            $rows = Import-Csv -Path $od.FileName -Delimiter $delim
            $added = 0
            foreach ($r in $rows) {
                $ip = ($r.ip, $r.IP, $r.Ip, $r.address | Where-Object { $_ } | Select-Object -First 1)
                if (-not $ip) { continue }
                $script:Targets = @($script:Targets) + @([pscustomobject]@{
                    ip = "$ip".Trim()
                    name = ("$($r.name)$($r.Name)").Trim()
                    community = if ("$($r.community)".Trim()) { "$($r.community)".Trim() } else { 'public' }
                    device_type = "$($r.device_type)".Trim()
                    snmp_version = if ("$($r.snmp_version)".Trim()) { "$($r.snmp_version)".Trim() } else { 'v2c' }
                    snmp_port = if ("$($r.snmp_port)".Trim()) { [int]$r.snmp_port } else { 161 }
                })
                $added++
            }
            Refresh-List $script:Targets
            [System.Windows.Forms.MessageBox]::Show("Importati $added target.", '86BIT Argus', 'OK', 'Information') | Out-Null
        } catch {
            [System.Windows.Forms.MessageBox]::Show('Errore import: ' + $_.Exception.Message, '86BIT Argus', 'OK', 'Error') | Out-Null
        }
    }
}

