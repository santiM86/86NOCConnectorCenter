function Refresh-Devices {
    if (-not $script:lvDevices) { return }
    $script:lvDevices.Items.Clear()
    foreach ($d in $script:Devices) {
        $it = New-Object System.Windows.Forms.ListViewItem $d.ip
        [void]$it.SubItems.Add([string]$d.community)
        [void]$it.SubItems.Add([string]$d.name)
        $it.Tag = $d
        [void]$script:lvDevices.Items.Add($it)
    }
}

