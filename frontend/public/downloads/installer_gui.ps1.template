function Build-ArgusIcon($Path) {
    # Genera un .ico 32x32 con sfondo blu e "86" bianco bold.
    # Niente file esterni: tutto disegnato runtime via System.Drawing.
    $bmp = New-Object System.Drawing.Bitmap 32, 32
    $g = [System.Drawing.Graphics]::FromImage($bmp)
    $g.SmoothingMode = [System.Drawing.Drawing2D.SmoothingMode]::AntiAlias
    $g.TextRenderingHint = [System.Drawing.Text.TextRenderingHint]::AntiAliasGridFit
    $brushBg = New-Object System.Drawing.SolidBrush ([System.Drawing.Color]::FromArgb(0, 122, 204))
    $g.FillEllipse($brushBg, 0, 0, 31, 31)
    $font = New-Object System.Drawing.Font("Segoe UI", 11, [System.Drawing.FontStyle]::Bold)
    $sf = New-Object System.Drawing.StringFormat
    $sf.Alignment = [System.Drawing.StringAlignment]::Center
    $sf.LineAlignment = [System.Drawing.StringAlignment]::Center
    $rect = New-Object System.Drawing.RectangleF(0, 1, 32, 32)
    $g.DrawString("86", $font, [System.Drawing.Brushes]::White, $rect, $sf)
    $g.Dispose()
    $hIcon = $bmp.GetHicon()
    $icon = [System.Drawing.Icon]::FromHandle($hIcon)
    $fs = New-Object System.IO.FileStream($Path, [System.IO.FileMode]::Create)
    try { $icon.Save($fs) } finally { $fs.Close() }
    $bmp.Dispose()
}

function Write-ConnectorLauncher {
    param([string]$Path, [string]$BackendUrl, [string]$ClientId, [string]$Role, [string]$Version)
    # Connector Console — UI 'Gestisci Dispositivi (SNMP Polling)' nello
    # stile del legacy v3.8.28. Permette di aggiungere/rimuovere target,
    # importare/esportare CSV, testare connettivita' e salvare il YAML
    # del agent con riavvio automatico del servizio. NON contiene piu' i
    # pulsanti Avvia/Ferma/Riavvia: quelli sono nel menu della tray icon.
    $body = @'
$ErrorActionPreference = 'SilentlyContinue'

try {
    $sig = @"
[DllImport("user32.dll")] public static extern bool ShowWindow(System.IntPtr hWnd, int nCmdShow);
[DllImport("kernel32.dll")] public static extern System.IntPtr GetConsoleWindow();
"@
    $w = Add-Type -MemberDefinition $sig -Name 'ConHider' -Namespace 'NocAgent' -PassThru
    $h = $w::GetConsoleWindow()
    if ($h -ne [System.IntPtr]::Zero) { [void]$w::ShowWindow($h, 0) }
} catch { }

Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing

$BackendUrl = '__BACKEND_URL__'
$ClientId   = '__CLIENT_ID__'
$RoleVal    = '__ROLE__'
$VersionVal = '__VERSION__'
$AgentToken = '__AGENT_TOKEN__'
$InstallDir = Split-Path -Parent $MyInvocation.MyCommand.Path
$IconPath   = Join-Path $InstallDir 'argus.ico'
$ConfigPath = Join-Path $env:ProgramData '86NocAgent\agent.yaml'

$ColAccent  = [System.Drawing.Color]::FromArgb(99, 102, 241)
$ColRed     = [System.Drawing.Color]::FromArgb(220, 53, 69)
$ColBlue    = [System.Drawing.Color]::FromArgb(13, 110, 253)
$ColPurple  = [System.Drawing.Color]::FromArgb(147, 51, 234)
$ColGreen   = [System.Drawing.Color]::FromArgb(34, 197, 94)
$ColMuted   = [System.Drawing.Color]::FromArgb(110, 110, 125)
$ColText    = [System.Drawing.Color]::FromArgb(33, 37, 41)
$ColWhite   = [System.Drawing.Color]::White

# ============================================================
# YAML helpers (markers per il blocco gestito dal Connector)
# ============================================================
$BeginMarker = '# === BEGIN MANAGED TARGETS ==='
$EndMarker   = '# === END MANAGED TARGETS ==='

function Parse-Targets {
    param([string]$ConfigText)
    $targets = @()
    $inBlock = $false
    $current = $null
    foreach ($line in $ConfigText -split "`r?`n") {
        if ($line -match '^\s*' + [regex]::Escape($BeginMarker)) { $inBlock = $true; continue }
        if ($line -match '^\s*' + [regex]::Escape($EndMarker)) { $inBlock = $false; if ($current) { $targets += [pscustomobject]$current; $current = $null }; continue }
        if (-not $inBlock) { continue }
        if ($line -match '^\s*-\s+ip:\s*"?([^"\s]+)"?') {
            if ($current) { $targets += [pscustomobject]$current }
            $current = @{ ip = $matches[1]; name=''; community='public'; device_type=''; snmp_version='v2c'; snmp_port=161 }
        } elseif ($current -and $line -match '^\s*name:\s*"?([^"]*)"?') {
            $current.name = $matches[1]
        } elseif ($current -and $line -match '^\s*community:\s*"?([^"]*)"?') {
            $current.community = $matches[1]
        } elseif ($current -and $line -match '^\s*profile:\s*"?([^"]*)"?') {
            $current.device_type = $matches[1]
        } elseif ($current -and $line -match '^\s*snmp_version:\s*"?([^"]*)"?') {
            $current.snmp_version = $matches[1]
        } elseif ($current -and $line -match '^\s*snmp_port:\s*(\d+)') {
            $current.snmp_port = [int]$matches[1]
        }
    }
    if ($current) { $targets += [pscustomobject]$current }
    return $targets
}

function Save-Targets {
    param([array]$Targets)
    if (-not (Test-Path $ConfigPath)) {
        [System.Windows.Forms.MessageBox]::Show("agent.yaml non trovato: $ConfigPath", '86BIT Argus', 'OK', 'Error') | Out-Null
        return $false
    }
    $raw = Get-Content -Raw -Path $ConfigPath
    $clean = ($raw -replace ('(?s)' + [regex]::Escape($BeginMarker) + '.*?' + [regex]::Escape($EndMarker) + "\r?\n?"), '').TrimEnd("`r","`n")

    $sb = New-Object System.Text.StringBuilder
    [void]$sb.AppendLine($BeginMarker)
    [void]$sb.AppendLine('# Gestito da Connector Console - non modificare a mano')
    [void]$sb.AppendLine('snmp_targets:')
    foreach ($t in $Targets) {
        [void]$sb.AppendLine(('  - ip: "' + $t.ip + '"'))
        if ($t.name)         { [void]$sb.AppendLine(('    name: "' + $t.name + '"')) }
        if ($t.community)    { [void]$sb.AppendLine(('    community: "' + $t.community + '"')) }
        if ($t.device_type)  { [void]$sb.AppendLine(('    profile: "' + $t.device_type + '"')) }
        if ($t.snmp_version) { [void]$sb.AppendLine(('    snmp_version: "' + $t.snmp_version + '"')) }
        if ($t.snmp_port -and [int]$t.snmp_port -ne 0) { [void]$sb.AppendLine(('    snmp_port: ' + [int]$t.snmp_port)) }
    }
    [void]$sb.AppendLine($EndMarker)

    $newContent = $clean + "`r`n" + $sb.ToString()
    Set-Content -Path $ConfigPath -Value $newContent -Encoding UTF8
    return $true
}

