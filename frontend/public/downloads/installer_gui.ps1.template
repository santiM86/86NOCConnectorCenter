    $sd.FileName = '86nocagent-targets.csv'
    if ($sd.ShowDialog() -eq 'OK') {
        $script:Targets | Select-Object ip, name, community, device_type, snmp_version, snmp_port |
            Export-Csv -Path $sd.FileName -NoTypeInformation -Encoding UTF8
        [System.Windows.Forms.MessageBox]::Show("Esportati $($script:Targets.Count) target.", '86BIT Argus', 'OK', 'Information') | Out-Null
