$btnTest = New-Btn 'Test SNMP' 200 595 130 $ColBlue $ColWhite {
    if ($lv.SelectedItems.Count -eq 0) {
        [System.Windows.Forms.MessageBox]::Show('Seleziona prima un dispositivo dalla tabella.', '86BIT Argus', 'OK', 'Information') | Out-Null
        return
    }
    $t = $lv.SelectedItems[0].Tag
    $script:lblTestSnmp.ForeColor = $ColMuted
    $script:lblTestSnmp.Text = "Interrogazione SNMP $($t.ip) in corso..."
    $form.Refresh()
    try {
        [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12 -bor [Net.SecurityProtocolType]::Tls13
        $body = @{ ip = $t.ip; community = $t.community; port = $t.snmp_port; version = $t.snmp_version } | ConvertTo-Json -Compress
        $url = $BackendUrl.TrimEnd('/') + '/api/agent/self/snmp/test?token=' + [System.Web.HttpUtility]::UrlEncode($AgentToken)
        # HttpUtility serve System.Web; fallback:
        if (-not ([type]'System.Web.HttpUtility' -as [type])) {
            Add-Type -AssemblyName System.Web | Out-Null
        }
        $r = Invoke-RestMethod -UseBasicParsing -Method Post -TimeoutSec 20 -Uri $url -ContentType 'application/json' -Body $body
        $reply = $r.reply
        if ($reply.ok -eq $true -and $reply.result) {
            $res = $reply.result
            $reachable = if ($res.reachable) { 'OK' } else { 'NON RAGGIUNGIBILE' }
            $msg = "IP: $($t.ip)`nReachable: $reachable`n"
            if ($res.sys_name)      { $msg += "sysName:     $($res.sys_name)`n" }
            if ($res.sys_descr)     { $msg += "sysDescr:    $($res.sys_descr)`n" }
            if ($res.sys_object_id) { $msg += "sysObjectID: $($res.sys_object_id)`n" }
            if ($res.uptime_ns)     { $msg += "Uptime:      $([TimeSpan]::FromTicks($res.uptime_ns/100))`n" }
            if ($res.latency_ns)    { $msg += "Latency:     $([int]($res.latency_ns/1e6)) ms`n" }
            if ($res.error)         { $msg += "Errore: $($res.error)`n" }
            [System.Windows.Forms.MessageBox]::Show($msg, '86BIT Argus - Test SNMP (via WS reale)', 'OK', 'Information') | Out-Null
            $script:lblTestSnmp.ForeColor = if ($res.reachable) { $ColGreen } else { $ColRed }
            $script:lblTestSnmp.Text = "Test SNMP $($t.ip): $reachable" + $(if ($res.sys_name) { " - $($res.sys_name)" } else { '' })
        } else {
            $script:lblTestSnmp.ForeColor = $ColRed
            $script:lblTestSnmp.Text = "Test fallito: $($reply.error)"
            [System.Windows.Forms.MessageBox]::Show("Errore agent: $($reply.error)", '86BIT Argus', 'OK', 'Error') | Out-Null
        }
    } catch {
        $script:lblTestSnmp.ForeColor = $ColRed
        $script:lblTestSnmp.Text = 'Errore HTTP: ' + $_.Exception.Message
        [System.Windows.Forms.MessageBox]::Show('Errore: ' + $_.Exception.Message, '86BIT Argus', 'OK', 'Error') | Out-Null
    }
}

