<#
.SYNOPSIS
    86NocAgent v4.0 - Wizard di Installazione

.DESCRIPTION
    Interfaccia grafica nativa Windows.Forms per installare e configurare
    il nuovo agent nativo Go (sostituisce il legacy 86NocConnector v3.8.x).

    Step:
      1. Welcome
      2. Configurazione (URL backend + API Key cliente)
      3. Riepilogo
      4. Installazione (download binari, sc.exe create, start service)
      5. Fine

.NOTES
    Auto-elevation UAC. Esegui semplicemente facendo doppio-click sul .vbs,
    oppure: powershell.exe -ExecutionPolicy Bypass -File installer_gui.ps1
#>

Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing

# ================================================================
# NASCONDI CONSOLE POWERSHELL
# ================================================================
# Il wizard viene avviato con -WindowStyle Hidden dal .bat, ma se
# qualcuno lo lancia diversamente (doppio-click sul .ps1, F5 da
# ISE, ecc.) la console "blu" rimane visibile dietro al wizard.
# Forziamo l'occultamento via Win32 ShowWindow API.
try {
    $hideSig = @'
[DllImport("user32.dll")] public static extern bool ShowWindow(System.IntPtr hWnd, int nCmdShow);
[DllImport("kernel32.dll")] public static extern System.IntPtr GetConsoleWindow();
'@
    $win = Add-Type -MemberDefinition $hideSig -Name 'NocConsoleHider' -Namespace 'NocAgent' -PassThru -ErrorAction SilentlyContinue
    $h = $win::GetConsoleWindow()
    if ($h -ne [System.IntPtr]::Zero) { [void]$win::ShowWindow($h, 0) }
} catch { }

# ================================================================
# AUTO-ELEVATION UAC
# ================================================================
$identity = [System.Security.Principal.WindowsIdentity]::GetCurrent()
$principal = New-Object System.Security.Principal.WindowsPrincipal($identity)
if (-not $principal.IsInRole([System.Security.Principal.WindowsBuiltInRole]::Administrator)) {
    try {
        $psi = New-Object System.Diagnostics.ProcessStartInfo
        $psi.FileName = "powershell.exe"
        $psi.Arguments = "-NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File `"$($MyInvocation.MyCommand.Path)`" $args"
        $psi.Verb = "runas"
        $psi.WindowStyle = [System.Diagnostics.ProcessWindowStyle]::Hidden
        $psi.UseShellExecute = $true
        [System.Diagnostics.Process]::Start($psi) | Out-Null
        exit 0
    } catch {
        [System.Windows.Forms.MessageBox]::Show(
            "Servono privilegi amministratore.`n`nTasto destro sul file -> 'Esegui come amministratore'",
            "86NocAgent - Privilegi insufficienti",
            [System.Windows.Forms.MessageBoxButtons]::OK,
            [System.Windows.Forms.MessageBoxIcon]::Warning) | Out-Null
        exit 1
    }
}

