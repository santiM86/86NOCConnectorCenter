$script:lstLog = $null
$script:progressBar = $null

function Append-Log($text, $color) {
    if (-not $color) { $color = $ColorText }
    try {
        $script:lstLog.SelectionColor = $color
    } catch { }
    $script:lstLog.AppendText("$text`r`n")
    $script:lstLog.ScrollToCaret()
    [System.Windows.Forms.Application]::DoEvents()
}

function fail-service($verb, $name, $err) {
    $msg = $err.Exception.Message
    Append-Log "      ERRORE $verb '$name': $msg" $ColorError
    throw "service $verb $name failed: $msg"
}

function Show-Install {
    Reset-Content
    $btnBack.Enabled = $false
    $btnNext.Enabled = $false
    $btnCancel.Enabled = $false

    $contentPanel.Controls.Add((New-Title "Installazione in corso"))
    $contentPanel.Controls.Add((New-Subtitle "Download dei binari, configurazione, registrazione servizi e avvio. Attendi il completamento."))

    $script:progressBar = New-Object System.Windows.Forms.ProgressBar
    $script:progressBar.Location = [System.Drawing.Point]::new(35, 175)
    $script:progressBar.Size = New-Object System.Drawing.Size(450, 22)
    $script:progressBar.Style = [System.Windows.Forms.ProgressBarStyle]::Continuous
    $script:progressBar.Minimum = 0
    $script:progressBar.Maximum = 100
    $contentPanel.Controls.Add($script:progressBar)

    $script:lstLog = New-Object System.Windows.Forms.RichTextBox
    $script:lstLog.Location = [System.Drawing.Point]::new(35, 210)
    $script:lstLog.Size = New-Object System.Drawing.Size(450, 220)
    $script:lstLog.ReadOnly = $true
    $script:lstLog.BackColor = [System.Drawing.Color]::FromArgb(28, 28, 35)
    $script:lstLog.ForeColor = [System.Drawing.Color]::FromArgb(220, 220, 230)
    $script:lstLog.Font = New-Object System.Drawing.Font("Consolas", 9)
    $script:lstLog.WordWrap = $false
    $contentPanel.Controls.Add($script:lstLog)

    [System.Windows.Forms.Application]::DoEvents()
    Run-Install
}

function Run-Install {
    $script:InstallResult = "fail"
    try {
        [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12 -bor [Net.SecurityProtocolType]::Tls13
        $url = $script:BackendUrl.TrimEnd('/')
        $tok = $script:Token

        Append-Log "[1/11] Lettura manifest installazione" $ColorAccent
        $script:progressBar.Value = 10
        $manifest = Invoke-RestMethod -UseBasicParsing -TimeoutSec 30 `
            -Uri "$url/api/agent/install/manifest?platform=$Platform&role=$($script:Role)&token=$tok"
        $script:ClientId = $manifest.client_id
        Append-Log "      cliente: $($manifest.client_id)  ruolo: $($script:Role)" $ColorSuccess

        # Costruttore URL binario: preferisce gli URL forniti direttamente
        # dal manifest (campo `binaries`), che il server puo' settare a un
        # mirror diverso dal NOC Center (es. CDN o ambiente di staging) via
        # env `AGENT_PUBLIC_HTTP_URL`. Fallback alla costruzione locale per
        # retro-compatibilita' con backend pre-1.7.
        function Get-BinaryUrl([string]$name) {
            if ($manifest.binaries -and $manifest.binaries.$name) {
                return [string]$manifest.binaries.$name
            }
            return "$url/api/agent/binary/$Platform/$name?token=$tok"
        }

        # Mirror di fallback: se il NOC Center configurato (es. argus.86bit.it)
        # non ha ancora i binari Windows depositati sul filesystem, ritentiamo
        # automaticamente il download da un mirror noto. Cosi' l'installazione
        # va a buon fine anche durante il rollout (deploy backend completato
        # prima che gli .exe siano stati copiati). Il connector poi gira contro
        # l'URL configurato dall'utente: il mirror serve SOLO al bootstrap.
        $script:BinaryMirror = "https://device-monitor-94.preview.emergentagent.com"

        function Download-BinaryWithFallback([string]$name, [string]$dst) {
            $binUrl = Get-BinaryUrl $name
            Append-Log "      $binUrl" $ColorMuted
            try {
                Invoke-WebRequest -UseBasicParsing -TimeoutSec 120 -Uri $binUrl -OutFile $dst
                return
            } catch {
                $code = if ($_.Exception.Response) { [int]$_.Exception.Response.StatusCode } else { 0 }
                if ($code -ne 404 -and $code -ne 500) { throw }
                # Fallback al mirror
                $mirror = "$($script:BinaryMirror)/api/agent/binary/$Platform/$name`?token=$tok"
                Append-Log "      WARN: 404 sul NOC Center, retry mirror" $ColorMuted
                Append-Log "      $mirror" $ColorMuted
                try {
                    Invoke-WebRequest -UseBasicParsing -TimeoutSec 180 -Uri $mirror -OutFile $dst
                } catch {
                    throw "$name non disponibile ne' sul NOC Center ($binUrl) ne' sul mirror ($mirror). Errore mirror: $($_.Exception.Message)"
                }
            }
        }

        Append-Log "[2/11] Stop servizi precedenti (se presenti)" $ColorAccent
        foreach ($s in @($WatchdogName, $ServiceName)) {
            $existing = Get-Service -Name $s -ErrorAction SilentlyContinue
            if ($null -ne $existing) {
                try { Stop-Service -Name $s -Force -ErrorAction SilentlyContinue } catch {}
                & cmd.exe /c "sc.exe delete `"$s`"" | Out-Null
                Start-Sleep -Milliseconds 800
                Append-Log "      $s rimosso" $ColorMuted
            }
        }
        $script:progressBar.Value = 20

        Append-Log "[3/11] Creazione directory" $ColorAccent
        New-Item -ItemType Directory -Force -Path $InstallDir | Out-Null
        New-Item -ItemType Directory -Force -Path $DataDir    | Out-Null
        # ACL: la GUI nocagent-ui.exe gira come utente normale, deve poter
        # leggere agent.yaml e scriverlo quando si clicca "Salva e Riavvia".
        # Concedi Modify al gruppo BUILTIN\Users (SID *S-1-5-32-545,
        # locale-indipendente) sulla cartella ProgramData. InstallDir
        # (Program Files) resta read-only per gli Users.
        try {
            & icacls.exe $DataDir "/grant" "*S-1-5-32-545:(OI)(CI)M" "/T" "/C" "/Q" 2>&1 | Out-Null
            Append-Log "      ACL Users:Modify applicate a $DataDir" $ColorMuted
        } catch {
            Append-Log "      WARN: icacls ACL fallito: $($_.Exception.Message)" $ColorMuted
        }
        $script:progressBar.Value = 30

        Append-Log "[4/11] Copia/Download nocagent.exe" $ColorAccent
        if ($script:HasLocalBinaries) {
            Copy-Item (Join-Path $script:LocalBinariesDir 'nocagent.exe') (Join-Path $InstallDir "nocagent.exe") -Force
            Append-Log "      copiato da bundle locale" $ColorMuted
        } else {
            Download-BinaryWithFallback 'nocagent.exe' (Join-Path $InstallDir "nocagent.exe")
        }
        $script:progressBar.Value = 55

        Append-Log "[5/11] Copia/Download nocwatchdog.exe + nocagent-ui.exe" $ColorAccent
        if ($script:HasLocalBinaries) {
            Copy-Item (Join-Path $script:LocalBinariesDir 'nocwatchdog.exe') (Join-Path $InstallDir "nocwatchdog.exe") -Force
            Copy-Item (Join-Path $script:LocalBinariesDir 'nocagent-ui.exe') (Join-Path $InstallDir "nocagent-ui.exe") -Force
            Append-Log "      copiati da bundle locale" $ColorMuted
        } else {
            Download-BinaryWithFallback 'nocwatchdog.exe' (Join-Path $InstallDir "nocwatchdog.exe")
            Download-BinaryWithFallback 'nocagent-ui.exe' (Join-Path $InstallDir "nocagent-ui.exe")
        }
        # Argus icon: prima da bundle locale, poi mirror.
        if ($script:HasLocalBinaries -and (Test-Path (Join-Path $script:LocalBinariesDir 'argus.ico'))) {
            Copy-Item (Join-Path $script:LocalBinariesDir 'argus.ico') (Join-Path $InstallDir "argus.ico") -Force
            Append-Log "      argus.ico copiato dal bundle" $ColorMuted
        } else {
            try {
                Invoke-WebRequest -UseBasicParsing -TimeoutSec 30 `
                    -Uri "$url/api/agent/install/argus.ico" `
                    -OutFile (Join-Path $InstallDir "argus.ico")
                Append-Log "      argus.ico scaricato" $ColorMuted
            } catch {
                try {
                    Invoke-WebRequest -UseBasicParsing -TimeoutSec 30 `
                        -Uri "$($script:BinaryMirror)/api/agent/install/argus.ico" `
                        -OutFile (Join-Path $InstallDir "argus.ico")
                    Append-Log "      argus.ico scaricato dal mirror" $ColorMuted
                } catch {
                    Append-Log "      WARN: argus.ico non scaricato (uso fallback EXE icon): $($_.Exception.Message)" $ColorMuted
                }
            }
        }
        $script:progressBar.Value = 70

        Append-Log "[6/11] Scrittura $ConfigPath" $ColorAccent
        $configContent = $manifest.config_template
        # Aggiungi blocco gestito target SNMP se l'utente ne ha forniti
        if ($script:Devices -and $script:Devices.Count -gt 0) {
            $sb = New-Object System.Text.StringBuilder
            [void]$sb.AppendLine('# === BEGIN MANAGED TARGETS ===')
            [void]$sb.AppendLine('# Gestito da Connector Console - non modificare a mano')
            [void]$sb.AppendLine('snmp_targets:')
            foreach ($d in $script:Devices) {
                [void]$sb.AppendLine(('  - ip: "' + $d.ip + '"'))
                if ($d.name)         { [void]$sb.AppendLine(('    name: "' + $d.name + '"')) }
                if ($d.community)    { [void]$sb.AppendLine(('    community: "' + $d.community + '"')) }
                if ($d.device_type)  { [void]$sb.AppendLine(('    profile: "' + $d.device_type + '"')) }
                if ($d.snmp_version) { [void]$sb.AppendLine(('    snmp_version: "' + $d.snmp_version + '"')) }
                if ($d.snmp_port -and [int]$d.snmp_port -ne 0) {
                    [void]$sb.AppendLine(('    snmp_port: ' + [int]$d.snmp_port))
                }
            }
            [void]$sb.AppendLine('# === END MANAGED TARGETS ===')
            $configContent = $configContent.TrimEnd("`r","`n") + "`r`n" + $sb.ToString()
            Append-Log "      $($script:Devices.Count) target SNMP scritti nel config" $ColorMuted
        }
        Set-Content -Path $ConfigPath -Value $configContent -Encoding UTF8
        $script:progressBar.Value = 80

        Append-Log "[7/11] Registrazione servizi Windows" $ColorAccent
        $agentBin    = Join-Path $InstallDir "nocagent.exe"
        $watchdogBin = Join-Path $InstallDir "nocwatchdog.exe"

        # Usa New-Service (cmdlet nativo PowerShell) per evitare i problemi di
        # parsing argomenti che ha sc.exe quando lanciato direttamente da PS.
        try {
            New-Service -Name $ServiceName `
                -BinaryPathName ('"' + $agentBin + '" --config "' + $ConfigPath + '"') `
                -DisplayName "86bit NOC Agent" `
                -Description "Native NOC monitoring agent for the 86bit platform." `
                -StartupType Automatic -ErrorAction Stop | Out-Null
            Append-Log "      $ServiceName creato" $ColorMuted
        } catch {
            fail-service "create" $ServiceName $_
        }

        try {
            New-Service -Name $WatchdogName `
                -BinaryPathName ('"' + $watchdogBin + '" --config "' + $ConfigPath + '"') `
                -DisplayName "86bit NOC Watchdog" `
                -Description "Supervises 86NocAgent and restarts it on hang or crash." `
                -StartupType Automatic `
                -DependsOn $ServiceName -ErrorAction Stop | Out-Null
            Append-Log "      $WatchdogName creato" $ColorMuted
        } catch {
            fail-service "create" $WatchdogName $_
        }

        # Service Recovery via sc.exe (no PowerShell-native equivalent).
        # Uso cmd /c per preservare la sintassi 'reset= 86400'.
        $recCmd1 = "sc.exe failure `"$ServiceName`" reset= 86400 actions= restart/5000/restart/5000/restart/15000"
        $recCmd2 = "sc.exe failure `"$WatchdogName`" reset= 86400 actions= restart/5000/restart/5000/restart/15000"
        & cmd.exe /c $recCmd1 | Out-Null
        & cmd.exe /c $recCmd2 | Out-Null
        $script:progressBar.Value = 90

        Append-Log "[8/11] Avvio servizi" $ColorAccent
        try {
            Start-Service -Name $ServiceName -ErrorAction Stop
        } catch {
            Append-Log "      WARN: avvio $ServiceName fallito: $($_.Exception.Message)" $ColorError
        }
        Start-Sleep -Seconds 2
        try {
            Start-Service -Name $WatchdogName -ErrorAction Stop
        } catch {
            Append-Log "      WARN: avvio $WatchdogName fallito: $($_.Exception.Message)" $ColorError
        }
        Start-Sleep -Seconds 2

        $ag = Get-Service -Name $ServiceName -ErrorAction SilentlyContinue
        $wd = Get-Service -Name $WatchdogName -ErrorAction SilentlyContinue
        $agStatus = if ($ag) { [string]$ag.Status } else { "MANCANTE" }
        $wdStatus = if ($wd) { [string]$wd.Status } else { "MANCANTE" }

        Append-Log "" $ColorText
        $agColor = if ($agStatus -eq "Running") { $ColorSuccess } else { $ColorError }
        $wdColor = if ($wdStatus -eq "Running") { $ColorSuccess } else { $ColorError }
        Append-Log ("      $ServiceName    : $agStatus") $agColor
        Append-Log ("      $WatchdogName : $wdStatus") $wdColor

        # ============================================================
        # [9/11] Configurazione Connector UI (nocagent-ui.exe)
        # nocagent-ui.exe e' la GUI nativa: sostituisce tray.ps1 e
        # connector.ps1. Niente PowerShell residente, niente console DOS.
        # ============================================================
        Append-Log "" $ColorText
        Append-Log "[9/11] Configurazione Connector UI" $ColorAccent
        try {
            $uiCfg = @{
                backend_url = $script:BackendUrl
                client_id   = $script:ClientId
                token       = $script:Token
                role        = $script:Role
                install_dir = $InstallDir
                config_path = $ConfigPath
                version     = $Version
            } | ConvertTo-Json -Depth 4
            Set-Content -Path (Join-Path $InstallDir "agent-ui.json") -Value $uiCfg -Encoding UTF8
            Append-Log "      agent-ui.json scritto" $ColorMuted
        } catch {
            Append-Log "      WARN: agent-ui.json non scritto: $($_.Exception.Message)" $ColorError
        }
        try {
            $startMenu = Join-Path $env:ProgramData "Microsoft\Windows\Start Menu\Programs\86BIT Argus Center"
            New-Item -ItemType Directory -Force -Path $startMenu | Out-Null
            $wsh = New-Object -ComObject WScript.Shell
            $uiExe = Join-Path $InstallDir "nocagent-ui.exe"
            $iconFile = Join-Path $InstallDir "argus.ico"
            $iconLoc = if (Test-Path $iconFile) { $iconFile } else { "$uiExe,0" }
            $lnk = $wsh.CreateShortcut((Join-Path $startMenu "Connector.lnk"))
            $lnk.TargetPath = $uiExe
            $lnk.Arguments = "-show"
            $lnk.WorkingDirectory = $InstallDir
            $lnk.IconLocation = $iconLoc
            $lnk.Description = "Apri Connector Argus - Gestisci Dispositivi"
            $lnk.Save()
            Append-Log "      shortcut '86BIT Argus Center\Connector' creato" $ColorMuted
        } catch {
            Append-Log "      WARN: shortcut non creato: $($_.Exception.Message)" $ColorError
        }
        $script:progressBar.Value = 95

        # ============================================================
        # [10/11] Autostart tray via Scheduled Task At Logon: lancia
        # nocagent-ui.exe nella sessione utente (no PowerShell, no DOS).
        # ============================================================
        Append-Log "[10/11] Registrazione autostart Connector UI" $ColorAccent
        $taskName = '86BIT Argus Tray'
        $uiExe = Join-Path $InstallDir "nocagent-ui.exe"
        # Cleanup eventuali autostart legacy (PowerShell-based)
        Remove-ItemProperty -Path 'HKLM:\Software\Microsoft\Windows\CurrentVersion\Run' -Name '86BITArgusTray' -Force -ErrorAction SilentlyContinue
        try {
            $action = New-ScheduledTaskAction -Execute $uiExe
            $trigger = New-ScheduledTaskTrigger -AtLogOn
            $principal = New-ScheduledTaskPrincipal -GroupId 'BUILTIN\Users' -RunLevel Limited
            $settings = New-ScheduledTaskSettingsSet `
                -AllowStartIfOnBatteries -DontStopIfGoingOnBatteries `
                -ExecutionTimeLimit ([TimeSpan]::Zero) `
                -RestartCount 5 -RestartInterval ([TimeSpan]::FromMinutes(1))
            Register-ScheduledTask -TaskName $taskName -Action $action -Trigger $trigger `
                -Principal $principal -Settings $settings -Force -ErrorAction Stop | Out-Null
            Append-Log "      scheduled task '$taskName' -> nocagent-ui.exe (At Logon)" $ColorMuted
            Start-ScheduledTask -TaskName $taskName -ErrorAction SilentlyContinue
            Append-Log "      tray icon avviata nella sessione utente" $ColorMuted
        } catch {
            Append-Log "      WARN: scheduled task non registrato: $($_.Exception.Message)" $ColorError
            try {
                $runKey = "HKLM:\Software\Microsoft\Windows\CurrentVersion\Run"
                Set-ItemProperty -Path $runKey -Name "86BITArgusTray" -Value $uiExe -Force
                Append-Log "      fallback HKLM\\Run registrato (parte al prossimo logon)" $ColorMuted
            } catch { }
        }

        # ============================================================
        # [11/11] Registrazione 'Programmi e funzionalita'' + uninstall.ps1
        # ============================================================
        Append-Log "[11/11] Registrazione Programmi e funzionalita'" $ColorAccent
        try {
            $uninstPath = Join-Path $InstallDir "uninstall.ps1"
            Write-UninstallScript -Path $uninstPath
            Append-Log "      uninstall.ps1 scritto" $ColorMuted
        } catch {
            Append-Log "      WARN: uninstall.ps1 non scritto: $($_.Exception.Message)" $ColorError
        }
        try {
            $uninstKey = "HKLM:\Software\Microsoft\Windows\CurrentVersion\Uninstall\86BITArgusAgent"
            if (-not (Test-Path $uninstKey)) {
                New-Item -Path $uninstKey -Force | Out-Null
            }
            $uninstCmd = "powershell.exe -NoProfile -WindowStyle Hidden -ExecutionPolicy Bypass -File `"$InstallDir\uninstall.ps1`""
            $sizeKb = 0
            try {
                $sizeBytes = (Get-ChildItem -Path $InstallDir -Recurse -ErrorAction SilentlyContinue | Measure-Object Length -Sum).Sum
                if ($sizeBytes) { $sizeKb = [int]($sizeBytes / 1024) }
            } catch { }
            Set-ItemProperty -Path $uninstKey -Name 'DisplayName'     -Value '86BIT Argus Connector'
            Set-ItemProperty -Path $uninstKey -Name 'DisplayVersion'  -Value $Version
            Set-ItemProperty -Path $uninstKey -Name 'Publisher'       -Value '86bit S.r.l.'
            Set-ItemProperty -Path $uninstKey -Name 'URLInfoAbout'    -Value 'https://www.86bit.it'
            Set-ItemProperty -Path $uninstKey -Name 'InstallLocation' -Value $InstallDir
            Set-ItemProperty -Path $uninstKey -Name 'UninstallString' -Value $uninstCmd
            Set-ItemProperty -Path $uninstKey -Name 'QuietUninstallString' -Value $uninstCmd
            $displayIcon = if (Test-Path (Join-Path $InstallDir "argus.ico")) { (Join-Path $InstallDir "argus.ico") } else { (Join-Path $InstallDir "nocagent-ui.exe") }
            Set-ItemProperty -Path $uninstKey -Name 'DisplayIcon'     -Value $displayIcon
            Set-ItemProperty -Path $uninstKey -Name 'NoModify'        -Value 1 -Type DWord
            Set-ItemProperty -Path $uninstKey -Name 'NoRepair'        -Value 1 -Type DWord
            if ($sizeKb -gt 0) {
                Set-ItemProperty -Path $uninstKey -Name 'EstimatedSize' -Value $sizeKb -Type DWord
            }
            Set-ItemProperty -Path $uninstKey -Name 'InstallDate'     -Value (Get-Date -Format 'yyyyMMdd')
            Append-Log "      voce 'Programmi e funzionalita'' registrata" $ColorMuted
        } catch {
            Append-Log "      WARN: registry Uninstall non scritto: $($_.Exception.Message)" $ColorError
        }
        try {
            # Aggiunge anche shortcut 'Disinstalla' nel menu Start
            $startMenu = Join-Path $env:ProgramData "Microsoft\Windows\Start Menu\Programs\86BIT Argus Center"
            if (-not (Test-Path $startMenu)) {
                New-Item -ItemType Directory -Force -Path $startMenu | Out-Null
            }
            $wsh = New-Object -ComObject WScript.Shell
            $unLnk = $wsh.CreateShortcut((Join-Path $startMenu "Disinstalla.lnk"))
            $unLnk.TargetPath = "powershell.exe"
            $unLnk.Arguments = "-NoProfile -WindowStyle Hidden -ExecutionPolicy Bypass -File `"$InstallDir\uninstall.ps1`""
            $unLnk.WorkingDirectory = $InstallDir
            $unLnk.IconLocation = if (Test-Path (Join-Path $InstallDir "argus.ico")) { (Join-Path $InstallDir "argus.ico") } else { (Join-Path $InstallDir "nocagent-ui.exe") + ",0" }
            $unLnk.Description = "Disinstalla 86BIT Argus Connector"
            $unLnk.Save()
            Append-Log "      shortcut 'Disinstalla' creato" $ColorMuted
        } catch {
            Append-Log "      WARN: shortcut Disinstalla non creato: $($_.Exception.Message)" $ColorError
        }
        # Forza il refresh della icon cache di Windows: senza questo gli
        # shortcut appena creati possono mostrare l'icona generica fino al
        # prossimo logon perche' Explorer cachea le icone per path.
        try {
            Start-Process -WindowStyle Hidden -FilePath "ie4uinit.exe" -ArgumentList "-show" -ErrorAction SilentlyContinue
        } catch {}

        $script:progressBar.Value = 100
        if ($agStatus -eq 'Running' -and $wdStatus -eq 'Running') {
            $script:InstallResult = "ok"
            Append-Log "" $ColorText
            Append-Log (([char]0x2713) + " Installazione completata con successo.") $ColorSuccess
        } else {
            Append-Log "" $ColorText
            Append-Log (([char]0x26A0) + " Installazione completata ma servizi NON in stato Running.") $ColorError
        }
    } catch {
        Append-Log ""
        Append-Log "ERRORE: $($_.Exception.Message)" $ColorError
        $script:InstallResult = "fail"
    }
    $btnNext.Enabled = $true
    $btnCancel.Enabled = $true
    $btnNext.Text = "Avanti >"
}

# ================================================================
# STEP 4 - FINE
# ================================================================
function Show-Done {
    Reset-Content
    $btnBack.Enabled = $false
    $btnNext.Text = "Chiudi"
    $btnCancel.Enabled = $false

    if ($script:InstallResult -eq "ok") {
        $contentPanel.Controls.Add((New-Title "Installazione completata"))
        $contentPanel.Controls.Add((New-Subtitle "Il connector e' attivo come Windows Service e si connettera' al NOC Center.`n`nIl supervisore (watchdog) lo manterra' in esecuzione anche in caso di crash o blocco di un modulo."))

        $box = New-Object System.Windows.Forms.GroupBox
        $box.Text = "Prossimi passi"
        $box.Location = [System.Drawing.Point]::new(35, 170)
        $box.Size = New-Object System.Drawing.Size(450, 220)
        $box.Font = New-Object System.Drawing.Font("Segoe UI", 9, [System.Drawing.FontStyle]::Bold)
        $contentPanel.Controls.Add($box)

        $items = @(
            "Menu Start -> 86BIT Argus Center -> Connector",
            "Tray icon visibile vicino all'orologio (zona notifica)",
            "Apri il NOC Center -> Agents per verificare 'live: true'",
            "Per disinstallare: Pannello di controllo -> Programmi"
        )
        for ($i = 0; $i -lt $items.Count; $i++) {
            $l = New-Object System.Windows.Forms.Label
            $l.Text = ([char]0x2192) + "  " + $items[$i]
            $l.Font = New-Object System.Drawing.Font("Segoe UI", 9.5)
            $l.ForeColor = $ColorText
            $l.Location = [System.Drawing.Point]::new(20, 30 + ($i * 30))
            $l.Size = New-Object System.Drawing.Size(420, 26)
            $box.Controls.Add($l)
        }
    } else {
        $contentPanel.Controls.Add((New-Title "Installazione fallita"))
        $contentPanel.Controls.Add((New-Subtitle "Si e' verificato un errore durante l'installazione.`n`nControlla il log dello step precedente. Eventuali servizi parzialmente registrati possono essere rimossi manualmente."))

        $box = New-Object System.Windows.Forms.GroupBox
        $box.Text = "Disinstallazione manuale"
        $box.Location = [System.Drawing.Point]::new(35, 170)
        $box.Size = New-Object System.Drawing.Size(450, 200)
        $box.Font = New-Object System.Drawing.Font("Segoe UI", 9, [System.Drawing.FontStyle]::Bold)
        $contentPanel.Controls.Add($box)

        $cmd = New-Object System.Windows.Forms.TextBox
        $cmd.Multiline = $true
        $cmd.ReadOnly = $true
        $cmd.ScrollBars = [System.Windows.Forms.ScrollBars]::Vertical
        $cmd.Font = New-Object System.Drawing.Font("Consolas", 9)
        $cmd.Location = [System.Drawing.Point]::new(15, 25)
        $cmd.Size = New-Object System.Drawing.Size(420, 160)
        $cmd.Text = @"
Stop-Service $ServiceName, $WatchdogName -Force -ErrorAction SilentlyContinue
sc.exe delete $ServiceName
sc.exe delete $WatchdogName
Remove-Item -Recurse -Force "$InstallDir","$DataDir"
"@
        $box.Controls.Add($cmd)
    }
}

# ================================================================
# NAVIGAZIONE
# ================================================================
function Render-Step {
    Update-Sidebar
    switch ($script:CurrentStep) {
        0 { Show-Welcome }
        1 { Show-Mode }
        2 { Show-Configuration }
        3 { Show-Devices }
        4 { Show-Summary }
        5 { Show-Install }
        6 { Show-Done }
    }
}

$btnNext.Add_Click({
    if ($script:CurrentStep -eq 1) {
        # Persiste la scelta del ruolo
        if ($script:rbScanner -ne $null -and $script:rbScanner.Checked) {
            $script:Role = "scanner"
        } else {
            $script:Role = "master"
        }
    }
    if ($script:CurrentStep -eq 2) {
        # Validazione step Configurazione
        $url = $script:txtUrl.Text.TrimEnd('/')
        $tok = $script:txtToken.Text.Trim()
        if (-not $url -or -not $tok) {
            [System.Windows.Forms.MessageBox]::Show("URL e API Key sono obbligatori.", "Configurazione incompleta",
                [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Warning) | Out-Null
            return
        }
        $script:BackendUrl = $url
        $script:Token = $tok
        if (-not $script:ClientId) {
            try {
                [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12 -bor [Net.SecurityProtocolType]::Tls13
                $r = Invoke-RestMethod -UseBasicParsing -TimeoutSec 15 `
                    -Uri "$url/api/agent/install/manifest?platform=$Platform&role=$($script:Role)&token=$tok"
                $script:ClientId = $r.client_id
            } catch {
                # Stesso parsing del bottone "Verifica connessione": estrae il
                # body JSON ({"detail":"..."}) per mostrare un errore parlante
                # invece del generico .NET "(403) Non consentito".
                $reason = ""
                try {
                    if ($_.Exception.Response) {
                        $stream = $_.Exception.Response.GetResponseStream()
                        $sr = New-Object System.IO.StreamReader($stream)
                        $body = $sr.ReadToEnd(); $sr.Close()
                        if ($body) {
                            try { $j = $body | ConvertFrom-Json; if ($j.detail) { $reason = [string]$j.detail } } catch { $reason = $body }
                        }
                        $code = [int]$_.Exception.Response.StatusCode
                        if ($code -eq 403 -and ($reason -match 'invalid token')) {
                            $reason = "API Key non valida o non registrata su questo NOC Center.`nVerifica di averla copiata dalla pagina Clienti -> API Key."
                        } elseif (-not $reason) {
                            $reason = "HTTP $code"
                        }
                    } else {
                        $reason = $_.Exception.Message
                    }
                } catch { $reason = $_.Exception.Message }
                [System.Windows.Forms.MessageBox]::Show("Verifica fallita:`n$reason", "Errore connessione",
                    [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Error) | Out-Null
                return
            }
        }
    }
    if ($script:CurrentStep -eq 3) {
        # Persisti il polling interval dal text box
        if ($script:txtPolling -and $script:txtPolling.Text) {
            $p = 0
            if ([int]::TryParse($script:txtPolling.Text.Trim(), [ref]$p) -and $p -gt 0) {
                $script:PollingSec = $p
            }
        }
    }
    if ($script:CurrentStep -eq 6) { $form.Close(); return }
    $script:CurrentStep++
    Render-Step
})

$btnBack.Add_Click({
    if ($script:CurrentStep -gt 0) {
        $script:CurrentStep--
        Render-Step
    }
})

$btnCancel.Add_Click({
    if ([System.Windows.Forms.MessageBox]::Show("Annullare l'installazione?", "$DisplayName",
        [System.Windows.Forms.MessageBoxButtons]::YesNo,
        [System.Windows.Forms.MessageBoxIcon]::Question) -eq [System.Windows.Forms.DialogResult]::Yes) {
        $form.Close()
    }
})

# ================================================================
# AVVIO
# ================================================================
Render-Step
[void]$form.ShowDialog()
